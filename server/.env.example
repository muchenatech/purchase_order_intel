OPENAI_API_KEY=your-key
OPENAI_MODEL=gpt-4.1-mini
PORT=3001
LOG_LEVEL=info
BOT_API_KEY=

SAP_ODATA_BASE_URL=https://your-sap-host/sap/opu/odata/sap/ZAI_POC_SRV
SAP_CLIENT=100
SAP_USERNAME=myuser
SAP_PASSWORD=fdfdfd
# Optional bearer token auth
# SAP_BEARER_TOKEN=your-token

# Path templates (use {poNumber} and {vendor} placeholders)
SAP_PO_DETAILS_PATH=/PurchaseOrderSet('{poNumber}')
SAP_VENDOR_DETAILS_PATH=/VendorSet('{vendor}')
SAP_PURCHASE_ORDERS_PATH=/PurchaseOrderSet

# SAP timeout in milliseconds
SAP_TIMEOUT_MS=15000